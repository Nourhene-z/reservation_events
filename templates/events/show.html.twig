{% extends 'base.html.twig' %}

{% block title %}{{ event.title }}{% endblock %}

{% block body %}
<div class="section-head">
    <h1>{{ event.title }}</h1>
    <span class="badge">Event details</span>
</div>

<section class="card event-panel">
    <div>
        {% if event.image %}
            <img class="event-poster" src="{{ event.image }}" alt="{{ event.title }}">
        {% else %}
            <div class="event-poster"></div>
        {% endif %}
        <p style="margin-top: 0.8rem;">{{ event.description }}</p>
    </div>
    <aside>
        <h2>Event Facts</h2>
        <ul class="mini-list">
            <li><strong>Date:</strong> {{ event.date|date('Y-m-d H:i') }}</li>
            <li><strong>Location:</strong> {{ event.location }}</li>
            <li><strong>Seats left:</strong> {{ event.seats }}</li>
            <li><strong>Status:</strong> {% if event.seats > 0 %}Available{% else %}Sold out{% endif %}</li>
        </ul>
    </aside>
</section>

<section class="card">
    <div class="section-head">
        <h2>Reserve a seat</h2>
        <span class="badge">Quick form</span>
    </div>

    {% if event.seats > 0 %}
        <form method="post" action="{{ path('reservation_create', {id: event.id}) }}">
            <label for="name">Name</label>
            <input id="name" name="name" type="text" required>

            <label for="email">Email</label>
            <input id="email" name="email" type="email" required>

            <label for="phone">Phone</label>
            <input id="phone" name="phone" type="text" required>

            <input type="hidden" name="_token" value="{{ csrf_token('reserve_event_' ~ event.id) }}">
            <button class="btn" type="submit">Confirm reservation</button>
        </form>
    {% else %}
        <p class="muted">This event is fully booked.</p>
    {% endif %}
</section>
{% endblock %}

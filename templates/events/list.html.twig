{% extends 'base.html.twig' %}

{% block title %}Events{% endblock %}

{% block body %}
<div class="section-head">
    <h1>Follow Event Schedule</h1>
    <span class="badge">All events</span>
</div>

<div class="event-listings">
    {% for event in events %}
        <article class="card event-row">
            {% if event.image %}
                <img class="event-image" src="{{ event.image }}" alt="{{ event.title }}">
            {% else %}
                <div class="event-image"></div>
            {% endif %}
            <div>
                <div class="event-meta">
                    <span class="badge">{{ event.date|date('M d') }}</span>
                    <span class="badge">{{ event.location }}</span>
                </div>
                <h2>{{ event.title }}</h2>
                <p class="muted">{{ event.description|slice(0, 120) }}{% if event.description|length > 120 %}...{% endif %}</p>
            </div>
            <div class="event-row-actions">
                <p><strong>Seats:</strong> {{ event.seats }}</p>
                <a class="btn" href="{{ path('event_show', {id: event.id}) }}">Buy Ticket</a>
            </div>
        </article>
    {% else %}
        <p class="muted">No events available.</p>
    {% endfor %}
</div>
{% endblock %}

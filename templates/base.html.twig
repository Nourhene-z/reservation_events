<!DOCTYPE html>
<html>
    <head>
        <meta charset="UTF-8">
        <title>{% block title %}Event Reservation{% endblock %}</title>
        <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>⚫️</text><text y=%221.3em%22 x=%220.2em%22 font-size=%2276%22 fill=%22%23fff%22>sf</text></svg>">
        {% block stylesheets %}{% endblock %}

        {% block javascripts %}
            {% block importmap %}{{ importmap('app') }}{% endblock %}
        {% endblock %}

        {% set frankenphpHotReload = app.request.server.get('FRANKENPHP_HOT_RELOAD') %}
        {% if frankenphpHotReload %}
        <meta name="frankenphp-hot-reload:url" content="{{ frankenphpHotReload }}">
        <script src="https://cdn.jsdelivr.net/npm/idiomorph"></script>
        <script src="https://cdn.jsdelivr.net/npm/frankenphp-hot-reload/+esm" type="module"></script>
        {% endif %}
    </head>
    <body>
        <nav class="site-nav">
            <div class="container">
                <a class="brand" href="{{ path('app_home') }}">EventFlow</a>
                <div class="nav-links">
                    <a href="{{ path('app_home') }}">Home</a>
                    <a href="{{ path('event_list') }}">Events</a>
                    {% if app.user and 'ROLE_ADMIN' in app.user.roles %}
                        <a href="{{ path('admin_dashboard') }}">Admin</a>
                    {% endif %}
                </div>
                <div class="nav-actions">
                    {% if app.user %}
                        <a href="{{ path('app_logout') }}">Logout</a>
                    {% else %}
                        <a href="{{ path('app_register') }}">Register</a>
                        <a class="primary-link" href="{{ path('app_admin_login') }}">Login</a>
                    {% endif %}
                </div>
            </div>
        </nav>

        <main class="container page-content">
            {% for message in app.flashes('success') %}
                <div class="flash success">{{ message }}</div>
            {% endfor %}
            {% for message in app.flashes('error') %}
                <div class="flash error">{{ message }}</div>
            {% endfor %}

            {% block body %}{% endblock %}

            <section class="footer-banner">
                <h2>Get Latest Updates Subscribe To Our Newsletter</h2>
                <p>Weekly event drops, spotlight artists, and early access reservations.</p>
            </section>
        </main>

        <footer class="site-footer">
            <div class="container">
                <div class="footer-col">
                    <h3>EventFlow</h3>
                    <p>Live moments, concerts, shows, and unforgettable nights.</p>
                    <p>Designed for fast booking and smooth event discovery.</p>
                </div>
                <div class="footer-col">
                    <h3>Upcoming Events</h3>
                    <a href="{{ path('event_list') }}">Global Music Festival</a>
                    <a href="{{ path('event_list') }}">Electronic Night</a>
                    <a href="{{ path('event_list') }}">Acoustic Summer Stage</a>
                </div>
                <div class="footer-col">
                    <h3>Quick Links</h3>
                    <a href="{{ path('app_home') }}">Home</a>
                    <a href="{{ path('event_list') }}">Events</a>
                    <a href="{{ path('app_admin_login') }}">Admin Login</a>
                </div>
                <div class="footer-col">
                    <h3>Contact</h3>
                    <p>support@eventflow.local</p>
                    <p>+216 00 000 000</p>
                    <p>Tunis, Tunisia</p>
                </div>
                <div class="footer-bottom" style="grid-column: 1 / -1;">
                    <span>Copyright 2026 EventFlow</span>
                    <span>Privacy Policy • Terms</span>
                </div>
            </div>
        </footer>
    </body>
</html>

{% extends 'base.html.twig' %}

{% block title %}Accueil{% endblock %}

{% block body %}
    <section class="hero">
        <span class="badge">Live Events</span>
        <h1>EVENT Vibes & Night Energy</h1>
        <p class="muted">Discover the next concerts, shows, and experiences. Reserve your seat in seconds and keep your event calendar always up to date.</p>
        <a class="btn" href="{{ path('event_list') }}">Explore all events</a>
    </section>

    <div class="section-head">
        <h2>Follow Event Schedule</h2>
        <span class="badge">Latest</span>
    </div>

    <div class="grid">
        {% for event in events %}
            <article class="card">
                {% if event.image %}
                    <img class="event-image" src="{{ event.image }}" alt="{{ event.title }}">
                {% endif %}
                <h2>{{ event.title }}</h2>
                <p class="muted">{{ event.date|date('Y-m-d H:i') }} - {{ event.location }}</p>
                <p>{{ event.description|slice(0, 130) }}{% if event.description|length > 130 %}...{% endif %}</p>
                <p><strong>Seats left:</strong> {{ event.seats }}</p>
                <a class="btn" href="{{ path('event_show', {id: event.id}) }}">View details</a>
            </article>
        {% else %}
            <p>No events available yet.</p>
        {% endfor %}
    </div>
{% endblock %}

{% extends 'base.html.twig' %}

{% block title %}Accueil{% endblock %}

{% block body %}
    <section class="hero">
        <span class="badge">Live Events</span>
        <h1>EVENT Vibes & Night Energy</h1>
        <p class="muted">Discover the next concerts, shows, and experiences. Reserve your seat in seconds and keep your event calendar always up to date.</p>
        <a class="btn" href="{{ path('event_list') }}">Explore all events</a>
    </section>

    <div class="section-head">
        <h2>Follow Event Schedule</h2>
        <span class="badge">Latest</span>
    </div>

    <div class="event-listings">
        {% for event in events %}
            <article class="card event-row">
                {% if event.image %}
                    <img class="event-image" src="{{ event.image }}" alt="{{ event.title }}">
                {% else %}
                    <div class="event-image"></div>
                {% endif %}
                <div>
                    <div class="event-meta">
                        <span class="badge">{{ event.date|date('M d') }}</span>
                        <span class="badge">{{ event.location }}</span>
                    </div>
                    <h2 class="event-title">{{ event.title }}</h2>
                    <p class="muted">{{ event.description|slice(0, 120) }}{% if event.description|length > 120 %}...{% endif %}</p>
                </div>
                <div class="event-row-actions">
                    <p class="event-seats"><strong>Seats:</strong> {{ event.seats }}</p>
                    <a class="btn" href="{{ path('event_show', {id: event.id}) }}">Buy Ticket</a>
                </div>
            </article>
        {% else %}
            <p class="muted">No events available yet.</p>
        {% endfor %}
    </div>
{% endblock %}
